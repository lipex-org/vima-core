{
  "name": "vima/core",
  "description": "Framework-agnostic RBAC + ABAC access control engine with pluggable storage backends and a built-in CLI.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Ian Ochieng",
      "email": "ochiengian383@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.5",
    "symfony/console": "^7.3",
    "symfony/var-dumper": "^7.3",
    "symfony/cache": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "Vima\\Core\\": "src/"
    },
    "files": [
      "src/functions.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Vima\\Core\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require-dev": {
    "phpunit/phpunit": "^13.2"
  }
}